  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "declaration": false,
    "noImplicitAny": false,
    "sourceMap": true,
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
